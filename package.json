{
  "name": "straylight-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:app": "npm run build && npm run desktop:test",
    "check:agent": "npm run agent:build && npm run agent:test-metadata",
    "tauri": "tauri",
    "probe:nina": "node tools/probe-nina-api.mjs",
    "agent:build": "dotnet build agents/Starrunner.Agent/Starrunner.Agent.csproj",
    "agent:test-metadata": "dotnet run --project agents/Starrunner.Agent.MetadataTests/Starrunner.Agent.MetadataTests.csproj",
    "agent:publish": "powershell -ExecutionPolicy Bypass -File tools/publish-starrunner-agent.ps1",
    "agent:fake-fits": "powershell -ExecutionPolicy Bypass -File tools/drop-fake-fits.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
